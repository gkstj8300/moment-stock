{
  "extends": "@repo/tsconfig/expo.json",
  "compilerOptions": {
    "declaration": false,
    "declarationMap": false,
    "types": [
      "node"
    ],
    "paths": {
      "@/*": [
        "./app/*"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx"
  ],
  "exclude": [
    "node_modules"
  ]
}
